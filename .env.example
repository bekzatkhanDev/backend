# ============================================================
# Backend Environment Configuration
# ============================================================
# Copy this file to .env and configure for your environment

# ------------------------------------------------------------
# Django Secret Key
# ------------------------------------------------------------
# For development: any random string
# For production: use a strong random string and keep it secret!
SECRET_KEY=your-secret-key-here-change-in-production

# ------------------------------------------------------------
# Debug Mode
# ------------------------------------------------------------
# True for development, False for production
DEBUG=True

# ------------------------------------------------------------
# Database Configuration
# ------------------------------------------------------------
POSTGRES_DB=taxservice
POSTGRES_USER=rasul
POSTGRES_PASSWORD=securepassword123

# ------------------------------------------------------------
# PGAdmin (optional - for database management)
# ------------------------------------------------------------
PGADMIN_DEFAULT_EMAIL=admin@gmail.com
PGADMIN_DEFAULT_PASSWORD=admin1234

# ------------------------------------------------------------
# Google API Key for routing service
# ------------------------------------------------------------
# Get your API key at: https://console.cloud.google.com/google/maps-apis/
# Note: Use the same key as EXPO_PUBLIC_GOOGLE_API_KEY in frontend
GOOGLE_API_KEY=your_google_api_key_here

# ------------------------------------------------------------
# CORS Configuration
# ------------------------------------------------------------
# Set to 'True' to allow all origins (development)
# Set to 'False' for production with restricted origins
CORS_ALLOW_ALL_ORIGINS=True

# ------------------------------------------------------------
# Host IP for Mobile Device Testing
# ------------------------------------------------------------
# This is your computer's local IP address. Set this when testing
# on physical devices (Expo Go on phone) or Android emulator.
#
# How to find your IP:
#   - Windows: Open CMD and run 'ipconfig'
#   - Mac: Open Terminal and run 'ipconfig getifaddr en0'
#   - Linux: Open Terminal and run 'hostname -I'
#
# Examples:
#   HOST_IP=192.168.1.100
#   HOST_IP=10.0.0.5
HOST_IP=localhost
